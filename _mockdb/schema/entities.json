{
  "version": "0.1",
  "description": "Entity definitions for the mock sample world. All formats use these shapes.",
  "entities": [
    {
      "name": "users",
      "idPrefix": "usr_",
      "fields": ["id", "name", "email", "role", "teamId", "createdAt"]
    },
    {
      "name": "profiles",
      "idPrefix": "prf_",
      "fields": ["id", "userId", "title", "bio", "location", "avatar"]
    },
    {
      "name": "teams",
      "idPrefix": "tm_",
      "fields": ["id", "name", "ownerId", "createdAt"]
    },
    {
      "name": "projects",
      "idPrefix": "prj_",
      "fields": ["id", "name", "ownerId", "teamId", "status", "createdAt"]
    },
    {
      "name": "tasks",
      "idPrefix": "tsk_",
      "fields": ["id", "projectId", "assigneeId", "title", "status", "dueDate", "createdAt"]
    },
    {
      "name": "products",
      "idPrefix": "prd_",
      "fields": ["id", "name", "description", "price", "currency", "category", "inStock"]
    },
    {
      "name": "orders",
      "idPrefix": "ord_",
      "fields": ["id", "userId", "productId", "amount", "currency", "status", "createdAt"]
    },
    {
      "name": "messages",
      "idPrefix": "msg_",
      "fields": ["id", "fromUserId", "toUserId", "body", "readAt", "createdAt"]
    },
    {
      "name": "notifications",
      "idPrefix": "ntf_",
      "fields": ["id", "userId", "type", "body", "read", "createdAt"]
    },
    {
      "name": "settings",
      "idPrefix": "stg_",
      "fields": ["id", "userId", "theme", "language", "notifications", "updatedAt"]
    },
    {
      "name": "activity_logs",
      "idPrefix": "log_",
      "fields": ["id", "userId", "action", "targetType", "targetId", "createdAt"]
    },
    {
      "name": "roles",
      "idPrefix": "role_",
      "fields": ["id", "name", "description"]
    },
    {
      "name": "permissions",
      "idPrefix": "perm_",
      "fields": ["id", "name", "resource", "action"]
    }
  ]
}
