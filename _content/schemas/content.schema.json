{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Content Placeholder Schema",
  "description": "Defines the expected shape of each placeholder content file in _content/placeholders/",
  "definitions": {
    "profile": {
      "type": "object",
      "required": ["name", "role", "bio", "email"],
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string" },
        "bio": { "type": "string" },
        "avatar": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "location": { "type": "string" },
        "social": {
          "type": "object",
          "properties": {
            "github": { "type": "string" },
            "linkedin": { "type": "string" },
            "twitter": { "type": "string" }
          }
        }
      }
    },
    "company": {
      "type": "object",
      "required": ["name", "tagline", "description"],
      "properties": {
        "name": { "type": "string" },
        "tagline": { "type": "string" },
        "description": { "type": "string" },
        "founded": { "type": "string" },
        "size": { "type": "string" },
        "industry": { "type": "string" },
        "website": { "type": "string" },
        "logo": { "type": "string" },
        "address": { "type": "object" },
        "contact": { "type": "object" }
      }
    },
    "service": {
      "type": "object",
      "required": ["id", "title", "slug", "summary"],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "summary": { "type": "string" },
        "description": { "type": "string" },
        "icon": { "type": "string" },
        "price": { "type": "string" },
        "features": { "type": "array", "items": { "type": "string" } },
        "cta": { "type": "string" }
      }
    },
    "product": {
      "type": "object",
      "required": ["id", "name", "slug", "price"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "summary": { "type": "string" },
        "description": { "type": "string" },
        "image": { "type": "string" },
        "price": { "type": "number" },
        "currency": { "type": "string" },
        "category": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "inStock": { "type": "boolean" },
        "cta": { "type": "string" }
      }
    },
    "testimonial": {
      "type": "object",
      "required": ["id", "author", "quote"],
      "properties": {
        "id": { "type": "string" },
        "author": { "type": "string" },
        "role": { "type": "string" },
        "company": { "type": "string" },
        "avatar": { "type": "string" },
        "quote": { "type": "string" },
        "rating": { "type": "integer", "minimum": 1, "maximum": 5 },
        "date": { "type": "string", "format": "date" }
      }
    },
    "faqItem": {
      "type": "object",
      "required": ["id", "question", "answer"],
      "properties": {
        "id": { "type": "string" },
        "question": { "type": "string" },
        "answer": { "type": "string" },
        "category": { "type": "string" }
      }
    }
  }
}
