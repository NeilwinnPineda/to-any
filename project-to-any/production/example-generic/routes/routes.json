{
  "basePath": "/",
  "defaultLayout": "marketing-layout",
  "notFound": "/404",
  "serverError": "/500",
  "authRedirect": "/login",
  "postLoginRedirect": "/dashboard",
  "routes": [
    { "path": "/",                    "view": "home",               "auth": false, "public": true },
    { "path": "/about",               "view": "about",              "auth": false, "public": true },
    { "path": "/contact",             "view": "contact",            "auth": false, "public": true },
    { "path": "/services",            "view": "services",           "auth": false, "public": true },
    { "path": "/services/:slug",      "view": "service-detail",     "auth": false, "public": true,  "dynamic": true },
    { "path": "/products",            "view": "products",           "auth": false, "public": true },
    { "path": "/products/:id",        "view": "product-detail",     "auth": false, "public": true,  "dynamic": true },
    { "path": "/pricing",             "view": "pricing",            "auth": false, "public": true },
    { "path": "/portfolio",           "view": "portfolio",          "auth": false, "public": true },
    { "path": "/case-studies",        "view": "case-studies",       "auth": false, "public": true },
    { "path": "/case-studies/:slug",  "view": "case-study-detail",  "auth": false, "public": true,  "dynamic": true },
    { "path": "/blog",                "view": "blog",               "auth": false, "public": true },
    { "path": "/blog/:slug",          "view": "blog-post",          "auth": false, "public": true,  "dynamic": true },
    { "path": "/docs",                "view": "docs-home",          "auth": false, "public": true },
    { "path": "/docs/:section/:slug", "view": "docs-article",       "auth": false, "public": true,  "dynamic": true },
    { "path": "/help",                "view": "help-center",        "auth": false, "public": true },
    { "path": "/faq",                 "view": "faq",                "auth": false, "public": true },
    { "path": "/search",              "view": "search-results",     "auth": false, "public": true },
    { "path": "/login",               "view": "login",              "auth": false, "redirectIfAuth": "/dashboard" },
    { "path": "/register",            "view": "register",           "auth": false, "redirectIfAuth": "/dashboard" },
    { "path": "/forgot-password",     "view": "forgot-password",    "auth": false },
    { "path": "/reset-password",      "view": "reset-password",     "auth": false },
    { "path": "/terms",               "view": "terms",              "auth": false, "public": true },
    { "path": "/privacy",             "view": "privacy",            "auth": false, "public": true },
    { "path": "/book",                "view": "booking",            "auth": false, "public": true },
    { "path": "/events/:slug",        "view": "event-page",         "auth": false, "public": true,  "dynamic": true },
    { "path": "/cart",                "view": "cart",               "auth": false },
    { "path": "/checkout",            "view": "checkout",           "auth": false },
    { "path": "/dashboard",           "view": "user-dashboard",     "auth": true,  "role": "user" },
    { "path": "/profile",             "view": "profile",            "auth": true,  "role": "user" },
    { "path": "/settings",            "view": "settings",           "auth": true,  "role": "user" },
    { "path": "/notifications",       "view": "notifications",      "auth": true,  "role": "user" },
    { "path": "/messages",            "view": "messages",           "auth": true,  "role": "user" },
    { "path": "/orders/:id",          "view": "order-summary",      "auth": true,  "role": "user",  "dynamic": true },
    { "path": "/onboarding",          "view": "onboarding",         "auth": true,  "role": "user" },
    { "path": "/admin",               "view": "admin-dashboard",    "auth": true,  "role": "admin" },
    { "path": "/analytics",           "view": "analytics-dashboard","auth": true,  "role": "admin" },
    { "path": "/404",                 "view": "error-404",          "auth": false },
    { "path": "/500",                 "view": "error-500",          "auth": false }
  ]
}
