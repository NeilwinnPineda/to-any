{
  "id": "example-generic",
  "label": "Example Generic Project",
  "description": "A fully populated example production project covering all 40 views, all layouts, all sections, and all content types. Use this as a reference or starting point for any project type.",
  "version": "0.1",
  "type": "generic",

  "stack": {
    "preferred": "mean",
    "alternatives": ["angular", "react", "next", "express-static", "static-html"]
  },

  "theme": {
    "base": "supercss/base",
    "mixer": "supercss/mixer",
    "default": {
      "theme": "base",
      "palette": "violet",
      "mode": "dark",
      "density": "comfortable",
      "radius": "soft",
      "motion": "subtle"
    },
    "override": "overrides/theme.css"
  },

  "content": "content/",
  "routes": "routes/routes.json",
  "viewMap": "view-map.json",
  "connectors": "connectors/",

  "compiler": {
    "layoutsDir": "../../templates/frontend/layouts",
    "sectionsDir": "../../templates/frontend/sections",
    "pagesDir": "../../templates/frontend/pages",
    "outputDir": "../../../dist/example-generic-{target}"
  },

  "features": {
    "auth": true,
    "ecommerce": true,
    "blog": true,
    "docs": true,
    "dashboard": true,
    "analytics": true,
    "bookings": true,
    "messaging": true
  }
}
