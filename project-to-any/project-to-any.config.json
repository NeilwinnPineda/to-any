{
  "version": "0.1",
  "description": "Master configuration for the project-to-any compiler. Declares available build targets, themes, palettes, connectors, and output conventions.",

  "targets": {
    "mean": {
      "label": "MEAN Stack",
      "stack": ["mongodb", "express", "angular", "node"],
      "templateDir": "_templates/angular",
      "apiDir": "_templates/express",
      "supercss": true,
      "default": true
    },
    "angular": {
      "label": "Angular (standalone, no API)",
      "stack": ["angular"],
      "templateDir": "_templates/angular",
      "supercss": true
    },
    "react": {
      "label": "React (Vite)",
      "stack": ["react"],
      "templateDir": "_templates/react",
      "supercss": true,
      "status": "planned"
    },
    "next": {
      "label": "Next.js (App Router)",
      "stack": ["react", "node"],
      "templateDir": "_templates/next",
      "supercss": true,
      "status": "planned"
    },
    "express-static": {
      "label": "Express + Static HTML",
      "stack": ["express", "node"],
      "templateDir": "_templates/express",
      "supercss": true
    },
    "ionic": {
      "label": "Ionic (Angular)",
      "stack": ["ionic", "angular", "capacitor"],
      "templateDir": "_templates/ionic",
      "supercss": false,
      "status": "planned"
    },
    "wordpress": {
      "label": "WordPress (theme)",
      "stack": ["php", "wordpress"],
      "templateDir": "_templates/wordpress",
      "supercss": false,
      "status": "planned"
    },
    "static-html": {
      "label": "Static HTML / Vanilla",
      "stack": ["html", "css", "js"],
      "templateDir": "_templates/static-html",
      "supercss": true,
      "status": "planned"
    }
  },

  "themes": ["base", "material", "fluent", "glass", "brutalist"],
  "palettes": ["violet", "blue", "emerald", "amber", "rose"],
  "modes": ["dark", "light"],
  "densities": ["compact", "comfortable", "spacious"],
  "radii": ["sharp", "soft", "round"],
  "motions": ["none", "subtle", "normal"],

  "connectors": {
    "database": {
      "label": "MongoDB",
      "file": "_templates/express/src/connectors/database.js",
      "optIn": true
    },
    "auth": {
      "label": "JWT Auth",
      "file": "_templates/express/src/connectors/auth.js",
      "optIn": true,
      "status": "planned"
    },
    "api": {
      "label": "External API Client",
      "file": "_templates/express/src/connectors/api.js",
      "optIn": true,
      "status": "planned"
    },
    "github": {
      "label": "GitHub Actions CI/CD",
      "file": "_templates/ci/github-actions.yml",
      "optIn": true,
      "status": "planned"
    },
    "deployment": {
      "label": "Deploy config (Vercel / Railway / Render)",
      "file": "_templates/deploy/",
      "optIn": true,
      "status": "planned"
    }
  },

  "output": {
    "dir": "../../dist",
    "pattern": "{project-id}-{target}",
    "clean": true
  },

  "compiler": {
    "rulesDir": "_rules",
    "templatesDir": "_templates",
    "supercssDir": "supercss",
    "contentDir": "_content",
    "mockdbDir": "_mockdb",
    "scriptsDir": "_scripts",
    "manifestFile": "production.manifest.json"
  },

  "defaults": {
    "target": "mean",
    "theme": "base",
    "palette": "violet",
    "mode": "dark",
    "density": "comfortable",
    "radius": "soft",
    "motion": "subtle"
  }
}
