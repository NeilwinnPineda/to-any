{
  "id": "docs-article",
  "label": "Docs Article",
  "path": "/docs/:section/:slug",
  "layout": "docs-layout",
  "sections": ["breadcrumbs", "sidebar-nav"],
  "content": ["pages.json"],
  "dynamic": true,
  "paramKey": "slug",
  "meta": {
    "title": "{{article.title}} — Docs — {{site.name}}",
    "description": "{{article.summary}}"
  },
  "auth": false,
  "targets": {
    "angular": "pages/docs-article/docs-article.component",
    "react": "pages/DocsArticlePage",
    "next": "app/docs/[section]/[slug]/page",
    "html": "pages/docs-article.html"
  }
}
