{
  "id": "booking",
  "label": "Booking / Appointment",
  "path": "/book",
  "layout": "form-heavy-layout",
  "sections": ["contact-form", "stats"],
  "content": ["site.json", "forms.json", "services.json"],
  "meta": {
    "title": "Book an appointment — {{site.name}}",
    "description": "Schedule a time that works for you."
  },
  "auth": false,
  "steps": ["service", "datetime", "details", "confirm"],
  "formRef": "forms.json#booking",
  "targets": {
    "angular": "pages/booking/booking.component",
    "react": "pages/BookingPage",
    "next": "app/book/page",
    "html": "pages/booking.html"
  }
}
