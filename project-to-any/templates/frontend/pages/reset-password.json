{
  "id": "reset-password",
  "label": "Reset Password",
  "path": "/reset-password",
  "layout": "auth-layout",
  "sections": ["contact-form"],
  "content": ["site.json", "forms.json"],
  "meta": {
    "title": "Reset password — {{site.name}}",
    "description": "Set a new password for your account."
  },
  "auth": false,
  "queryParam": "token",
  "formRef": "forms.json#resetPassword",
  "targets": {
    "angular": "pages/reset-password/reset-password.component",
    "react": "pages/ResetPasswordPage",
    "next": "app/(auth)/reset-password/page",
    "html": "pages/reset-password.html"
  }
}
