{
  "id": "forgot-password",
  "label": "Forgot Password",
  "path": "/forgot-password",
  "layout": "auth-layout",
  "sections": ["contact-form"],
  "content": ["site.json", "forms.json"],
  "meta": {
    "title": "Forgot password — {{site.name}}",
    "description": "Reset your account password."
  },
  "auth": false,
  "formRef": "forms.json#forgotPassword",
  "targets": {
    "angular": "pages/forgot-password/forgot-password.component",
    "react": "pages/ForgotPasswordPage",
    "next": "app/(auth)/forgot-password/page",
    "html": "pages/forgot-password.html"
  }
}
