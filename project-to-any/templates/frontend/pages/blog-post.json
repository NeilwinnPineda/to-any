{
  "id": "blog-post",
  "label": "Blog Post",
  "path": "/blog/:slug",
  "layout": "blog-layout",
  "sections": ["breadcrumbs", "blog-list", "newsletter-signup"],
  "content": ["blog.json"],
  "dynamic": true,
  "paramKey": "slug",
  "dataSource": "blog.json#posts[slug]",
  "meta": {
    "title": "{{post.title}} — {{site.name}}",
    "description": "{{post.excerpt}}"
  },
  "auth": false,
  "targets": {
    "angular": "pages/blog-post/blog-post.component",
    "react": "pages/BlogPostPage",
    "next": "app/blog/[slug]/page",
    "html": "pages/blog-post.html"
  }
}
