{
  "id": "cart",
  "label": "Cart",
  "path": "/cart",
  "layout": "ecommerce-layout",
  "sections": ["product-grid", "cta"],
  "content": ["products.json"],
  "meta": {
    "title": "Cart — {{site.name}}",
    "description": "Review your cart before checkout."
  },
  "auth": false,
  "targets": {
    "angular": "pages/cart/cart.component",
    "react": "pages/CartPage",
    "next": "app/(shop)/cart/page",
    "html": "pages/cart.html"
  }
}
