{
  "id": "product-detail",
  "label": "Product Detail",
  "path": "/products/:id",
  "layout": "ecommerce-layout",
  "sections": ["breadcrumbs", "product-grid", "testimonials", "cta"],
  "content": ["products.json"],
  "dynamic": true,
  "paramKey": "id",
  "dataSource": "products.json#items[id]",
  "meta": {
    "title": "{{product.name}} — {{site.name}}",
    "description": "{{product.description}}"
  },
  "auth": false,
  "targets": {
    "angular": "pages/product-detail/product-detail.component",
    "react": "pages/ProductDetailPage",
    "next": "app/products/[id]/page",
    "html": "pages/product-detail.html"
  }
}
