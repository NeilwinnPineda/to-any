{
  "id": "event-page",
  "label": "Event Page",
  "path": "/events/:slug",
  "layout": "fullscreen-hero-layout",
  "sections": ["hero", "stats", "timeline", "testimonials", "contact-form", "cta"],
  "content": ["pages.json", "forms.json"],
  "meta": {
    "title": "{{event.name}} — {{site.name}}",
    "description": "{{event.description}}"
  },
  "auth": false,
  "dynamic": true,
  "paramKey": "slug",
  "targets": {
    "angular": "pages/event/event-page.component",
    "react": "pages/EventPage",
    "next": "app/events/[slug]/page",
    "html": "pages/event-page.html"
  }
}
