{
  "id": "checkout",
  "label": "Checkout",
  "path": "/checkout",
  "layout": "form-heavy-layout",
  "sections": ["contact-form", "product-grid"],
  "content": ["products.json", "forms.json"],
  "meta": {
    "title": "Checkout — {{site.name}}",
    "description": "Complete your order."
  },
  "auth": false,
  "steps": ["shipping", "payment", "review"],
  "formRef": "forms.json#checkout",
  "targets": {
    "angular": "pages/checkout/checkout.component",
    "react": "pages/CheckoutPage",
    "next": "app/(shop)/checkout/page",
    "html": "pages/checkout.html"
  }
}
