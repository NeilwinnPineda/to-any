{
  "id": "search-results",
  "label": "Search Results",
  "path": "/search",
  "layout": "topbar-layout",
  "sections": ["search-bar", "filter-panel", "blog-list"],
  "content": ["site.json"],
  "meta": {
    "title": "Search: {{query}} — {{site.name}}",
    "description": "Search results for {{query}}"
  },
  "auth": false,
  "queryParam": "q",
  "targets": {
    "angular": "pages/search/search-results.component",
    "react": "pages/SearchResultsPage",
    "next": "app/search/page",
    "html": "pages/search-results.html"
  }
}
