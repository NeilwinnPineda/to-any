{
  "id": "contact",
  "label": "Contact",
  "path": "/contact",
  "layout": "marketing-layout",
  "sections": ["contact-form"],
  "content": ["site.json", "pages.json", "forms.json"],
  "meta": {
    "title": "Contact — {{site.name}}",
    "description": "Get in touch with our team."
