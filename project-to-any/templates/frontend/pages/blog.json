{
  "id": "blog",
  "label": "Blog",
  "path": "/blog",
  "layout": "blog-layout",
  "sections": ["search-bar", "filter-panel", "blog-list", "newsletter-signup"],
  "content": ["blog.json"],
  "meta": {
    "title": "Blog — {{site.name}}",
    "description": "Insights, tutorials, and updates from the team."
