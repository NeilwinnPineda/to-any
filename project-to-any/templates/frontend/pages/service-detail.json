{
  "id": "service-detail",
  "label": "Service Detail",
  "path": "/services/:slug",
  "layout": "marketing-layout",
  "sections": ["breadcrumbs", "hero", "feature-grid", "testimonials", "cta"],
  "content": ["services.json", "testimonials.json"],
  "dynamic": true,
  "paramKey": "slug",
  "dataSource": "services.json#items[slug]",
  "meta": {
    "title": "{{service.name}} — {{site.name}}",
    "description": "{{service.description}}"
  },
  "auth": false,
  "targets": {
    "angular": "pages/service-detail/service-detail.component",
    "react": "pages/ServiceDetailPage",
    "next": "app/services/[slug]/page",
    "html": "pages/service-detail.html"
  }
}
