{
  "id": "grid-heavy-layout",
  "label": "Grid-Heavy Layout",
  "description": "Multi-column responsive grid layout for high-density browsing: portfolio, gallery, product catalog, admin tables. No sidebar, wide grid canvas.",
  "regions": ["topbar", "filters", "grid-main", "footer"],
  "defaultSections": {
    "topbar": "site-header",
    "filters": "filter-panel",
    "footer": "site-footer"
  },
  "supercss": {
    "theme": "base",
    "density": "compact",
    "radius": "soft"
  },
  "gridColumns": "auto-fill",
  "gridMinItemWidth": "280px",
  "maxContentWidth": "1400px",
  "targets": {
    "angular": "layouts/grid-heavy/grid-heavy.layout.component",
    "react": "layouts/GridHeavyLayout",
    "next": "app/(grid)/layout",
    "html": "layouts/grid-heavy.html"
  }
}
