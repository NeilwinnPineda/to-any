{
  "id": "marketing-layout",
  "label": "Marketing Layout",
  "description": "Standard public-facing layout: sticky topbar, wide content area, rich footer. Used for landing pages, about, pricing, contact.",
  "regions": ["topbar", "main", "footer"],
  "defaultSections": {
    "topbar": "site-header",
    "footer": "site-footer"
  },
  "supercss": {
    "theme": "base",
    "density": "comfortable",
    "radius": "soft"
  },
  "maxContentWidth": "1200px",
  "targets": {
    "angular": "layouts/marketing/marketing.layout.component",
    "react": "layouts/MarketingLayout",
    "next": "app/(marketing)/layout",
    "html": "layouts/marketing.html"
  }
}
