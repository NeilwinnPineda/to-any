{
  "id": "app-shell-layout",
  "label": "App Shell Layout",
  "description": "Full-height authenticated shell: fixed sidebar nav, sticky topbar, scrollable main area. Used for dashboards, settings, profile.",
  "regions": ["topbar", "sidebar", "main"],
  "defaultSections": {
    "topbar": "app-topbar",
    "sidebar": "sidebar-nav"
  },
  "supercss": {
    "theme": "base",
    "density": "compact",
    "radius": "soft"
  },
  "grid": "sidebar+main",
  "sidebarWidth": "240px",
  "topbarHeight": "52px",
  "targets": {
    "angular": "layouts/app-shell/app-shell.layout.component",
    "react": "layouts/AppShellLayout",
    "next": "app/(app)/layout",
    "html": "layouts/app-shell.html"
  }
}
