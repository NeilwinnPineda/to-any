{
  "id": "docs-layout",
  "label": "Docs Layout",
  "description": "Documentation layout: fixed left sidebar with section tree, wide main article area, optional right TOC panel. Used for docs home and articles.",
  "regions": ["topbar", "sidebar", "main", "toc"],
  "defaultSections": {
    "topbar": "docs-topbar",
    "sidebar": "docs-sidebar-nav",
    "toc": "toc-panel"
  },
  "supercss": {
    "theme": "base",
    "density": "comfortable",
    "radius": "soft"
  },
  "sidebarWidth": "260px",
  "tocWidth": "220px",
  "maxContentWidth": "860px",
  "targets": {
    "angular": "layouts/docs/docs.layout.component",
    "react": "layouts/DocsLayout",
    "next": "app/(docs)/layout",
    "html": "layouts/docs.html"
  }
}
