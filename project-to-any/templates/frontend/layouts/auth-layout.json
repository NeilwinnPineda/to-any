{
  "id": "auth-layout",
  "label": "Auth Layout",
  "description": "Minimal centered layout for authentication flows: login, register, forgot/reset password. No nav, no footer.",
  "regions": ["main"],
  "defaultSections": {},
  "supercss": {
    "theme": "base",
    "density": "comfortable",
    "radius": "soft"
  },
  "centered": true,
  "maxFormWidth": "400px",
  "background": "surface",
  "targets": {
    "angular": "layouts/auth/auth.layout.component",
    "react": "layouts/AuthLayout",
    "next": "app/(auth)/layout",
    "html": "layouts/auth.html"
  }
}
