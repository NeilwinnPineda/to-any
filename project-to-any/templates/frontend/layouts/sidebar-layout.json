{
  "id": "sidebar-layout",
  "label": "Sidebar Layout",
  "description": "General-purpose sidebar + main content layout without a fixed topbar. Used for settings, profile, help center, and structured content pages.",
  "regions": ["sidebar", "main"],
  "defaultSections": {
    "sidebar": "sidebar-nav"
  },
  "supercss": {
    "theme": "base",
    "density": "comfortable",
    "radius": "soft"
  },
  "sidebarWidth": "240px",
  "sidebarPosition": "left",
  "targets": {
    "angular": "layouts/sidebar/sidebar.layout.component",
    "react": "layouts/SidebarLayout",
    "next": "app/(sidebar)/layout",
    "html": "layouts/sidebar.html"
  }
}
