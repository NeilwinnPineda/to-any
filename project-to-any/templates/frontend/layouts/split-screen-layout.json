{
  "id": "split-screen-layout",
  "label": "Split-Screen Layout",
  "description": "50/50 or 60/40 split: left panel (media/brand) + right panel (form/content). Used for login, register, onboarding, and landing alternating sections.",
  "regions": ["left-panel", "right-panel"],
  "defaultSections": {},
  "supercss": {
    "theme": "base",
    "density": "comfortable",
    "radius": "soft"
  },
  "split": "50/50",
  "variants": ["50/50", "60/40", "40/60"],
  "leftBackground": "brand",
  "rightBackground": "surface",
  "targets": {
    "angular": "layouts/split-screen/split-screen.layout.component",
    "react": "layouts/SplitScreenLayout",
    "next": "app/(split)/layout",
    "html": "layouts/split-screen.html"
  }
}
