{
  "id": "blog-layout",
  "label": "Blog Layout",
  "description": "Editorial layout: centered readable column with optional right sidebar for related/categories. Used for blog list and blog post views.",
  "regions": ["topbar", "main", "sidebar", "footer"],
  "defaultSections": {
    "topbar": "site-header",
    "footer": "site-footer"
  },
  "supercss": {
    "theme": "base",
    "density": "comfortable",
    "radius": "soft"
  },
  "maxContentWidth": "720px",
  "sidebarWidth": "300px",
  "typographyScale": "editorial",
  "targets": {
    "angular": "layouts/blog/blog.layout.component",
    "react": "layouts/BlogLayout",
    "next": "app/(blog)/layout",
    "html": "layouts/blog.html"
  }
}
