{
  "id": "fullscreen-hero-layout",
  "label": "Fullscreen Hero Layout",
  "description": "100vh first section with overlay nav, large headline, CTA. Remaining sections scroll below. Used for product launches, events, case studies.",
  "regions": ["hero-overlay-nav", "hero-main", "content", "footer"],
  "defaultSections": {
    "hero-overlay-nav": "overlay-nav",
    "footer": "site-footer"
  },
  "supercss": {
    "theme": "base",
    "density": "spacious",
    "radius": "soft"
  },
  "heroHeight": "100vh",
  "overlayNav": true,
  "targets": {
    "angular": "layouts/fullscreen-hero/fullscreen-hero.layout.component",
    "react": "layouts/FullscreenHeroLayout",
    "next": "app/(hero)/layout",
    "html": "layouts/fullscreen-hero.html"
  }
}
