{
  "id": "logo-cloud",
  "label": "Logo Cloud",
  "description": "Horizontal strip of partner/client logos. Supports auto-scroll marquee or static grid.",
  "variants": ["static-grid", "marquee", "with-label"],
  "defaultVariant": "static-grid",
  "contentKey": "logos",
  "fields": {
    "label": { "type": "string", "required": false, "default": "Trusted by teams at" },
    "items": {
      "type": "array",
      "schema": {
        "name": "string",
        "logo": "string",
        "href": "string|null"
      },
      "required": true
    },
    "marquee": { "type": "boolean", "default": false }
  },
  "cssTokens": ["--sc-muted", "--sc-surface", "--sc-border"],
  "targets": {
    "angular": "sections/logo-cloud/logo-cloud.section.component",
    "react": "sections/LogoCloud",
    "html": "sections/logo-cloud.html"
  }
}
