{
  "id": "pricing-table",
  "label": "Pricing Table",
  "description": "Tiered pricing cards with feature lists, highlighted recommended tier, toggle for monthly/annual billing.",
  "variants": ["3-tier", "2-tier", "4-tier", "comparison-table"],
  "defaultVariant": "3-tier",
  "contentKey": "pricing",
  "fields": {
    "headline": { "type": "string", "required": false },
    "billingToggle": { "type": "boolean", "default": true },
    "tiers": {
      "type": "array",
      "schema": {
        "id": "string",
        "name": "string",
        "price": { "monthly": "string", "annual": "string" },
        "description": "string",
        "features": "string[]",
        "cta": { "label": "string", "href": "string" },
        "highlighted": "boolean",
        "badge": "string|null"
      },
      "required": true
    }
  },
  "cssTokens": ["--sc-primary", "--sc-surface", "--sc-border", "--sc-text", "--sc-radius"],
  "targets": {
    "angular": "sections/pricing-table/pricing-table.section.component",
    "react": "sections/PricingTable",
    "html": "sections/pricing-table.html"
  }
}
