{
  "id": "stats",
  "label": "Stats / Metrics",
  "description": "Row or grid of headline numbers with labels. Supports animated count-up on scroll.",
  "variants": ["row", "grid", "centered", "with-icon", "dark-band"],
  "defaultVariant": "row",
  "contentKey": "stats",
  "fields": {
    "headline": { "type": "string", "required": false },
    "items": {
      "type": "array",
      "schema": {
        "value": "string",
        "label": "string",
        "prefix": "string|null",
        "suffix": "string|null",
        "icon": "string|null"
      },
      "required": true
    },
    "animateOnScroll": { "type": "boolean", "default": true }
  },
  "cssTokens": ["--sc-primary", "--sc-text", "--sc-bg", "--sc-surface"],
  "targets": {
    "angular": "sections/stats/stats.section.component",
    "react": "sections/StatsSection",
    "html": "sections/stats.html"
  }
}
