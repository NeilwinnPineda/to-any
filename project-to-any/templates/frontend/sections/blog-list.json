{
  "id": "blog-list",
  "label": "Blog List",
  "description": "List or grid of blog post previews: cover image, category, title, excerpt, author, date.",
  "variants": ["card-grid", "editorial-list", "featured-first", "compact-list"],
  "defaultVariant": "card-grid",
  "contentKey": "blog",
  "fields": {
    "headline": { "type": "string", "required": false },
    "showCategories": { "type": "boolean", "default": true },
    "showAuthor": { "type": "boolean", "default": true },
    "items": {
      "type": "array",
      "schema": {
        "id": "string",
        "title": "string",
        "excerpt": "string",
        "category": "string",
        "author": { "name": "string", "avatar": "string" },
        "date": "string",
        "readTime": "string",
        "image": "string",
        "href": "string",
        "featured": "boolean"
      },
      "required": true
    }
  },
  "cssTokens": ["--sc-surface", "--sc-border", "--sc-text", "--sc-primary", "--sc-radius"],
  "targets": {
    "angular": "sections/blog-list/blog-list.section.component",
    "react": "sections/BlogList",
    "html": "sections/blog-list.html"
  }
}
