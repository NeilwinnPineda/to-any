{
  "id": "cta",
  "label": "Call to Action",
  "description": "Full-width CTA band with headline, supporting text, and one or two buttons. Used at end of sections or pages.",
  "variants": ["centered", "left-aligned", "split", "banner", "inline"],
  "defaultVariant": "centered",
  "contentKey": "cta",
  "fields": {
    "headline": { "type": "string", "required": true },
    "body": { "type": "string", "required": false },
    "ctaPrimary": { "type": "object", "schema": { "label": "string", "href": "string" } },
    "ctaSecondary": { "type": "object", "schema": { "label": "string", "href": "string" } },
    "background": { "type": "enum", "values": ["primary", "surface", "gradient", "dark"], "default": "primary" }
  },
  "cssTokens": ["--sc-primary", "--sc-text", "--sc-bg", "--sc-radius"],
  "targets": {
    "angular": "sections/cta/cta.section.component",
    "react": "sections/CtaSection",
    "html": "sections/cta.html"
  }
}
