{
  "id": "timeline",
  "label": "Timeline",
  "description": "Chronological list of events or milestones. Used for company history, project roadmap, or onboarding steps.",
  "variants": ["vertical", "horizontal", "alternating", "steps"],
  "defaultVariant": "vertical",
  "contentKey": "timeline",
  "fields": {
    "headline": { "type": "string", "required": false },
    "items": {
      "type": "array",
      "schema": {
        "date": "string",
        "title": "string",
        "description": "string",
        "icon": "string|null",
        "media": "string|null"
      },
      "required": true
    }
  },
  "cssTokens": ["--sc-primary", "--sc-surface", "--sc-border", "--sc-text"],
  "targets": {
    "angular": "sections/timeline/timeline.section.component",
    "react": "sections/Timeline",
    "html": "sections/timeline.html"
  }
}
