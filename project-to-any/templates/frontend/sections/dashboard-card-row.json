{
  "id": "dashboard-card-row",
  "label": "Dashboard Card Row",
  "description": "Row of KPI metric cards: value, label, trend indicator, and optional sparkline. Standard dashboard top-row pattern.",
  "variants": ["4-cards", "3-cards", "5-cards", "with-sparkline", "compact"],
  "defaultVariant": "4-cards",
  "contentKey": "dashboard.metrics",
  "fields": {
    "cards": {
      "type": "array",
      "schema": {
        "label": "string",
        "value": "string",
        "change": "string|null",
        "changeDirection": "up|down|neutral",
        "period": "string|null",
        "icon": "string|null",
        "color": "primary|success|warning|danger|neutral",
        "sparkline": "number[]|null"
      },
      "required": true
    }
  },
  "cssTokens": ["--sc-surface", "--sc-border", "--sc-text", "--sc-primary", "--sc-shadow-sm"],
  "targets": {
    "angular": "sections/dashboard-cards/dashboard-card-row.section.component",
    "react": "sections/DashboardCardRow",
    "html": "sections/dashboard-card-row.html"
  }
}
