{
  "id": "contact-form",
  "label": "Contact Form",
  "description": "Form section with name, email, message fields plus optional phone, company, subject. Includes success/error states.",
  "variants": ["simple", "with-map", "with-contact-info", "split-with-details"],
  "defaultVariant": "with-contact-info",
  "contentKey": "contact",
  "fields": {
    "headline": { "type": "string", "required": false },
    "subheadline": { "type": "string", "required": false },
    "contactInfo": {
      "email": "string",
      "phone": "string|null",
      "address": "string|null"
    },
    "formFields": { "type": "array", "ref": "forms.json#contact" },
    "submitLabel": { "type": "string", "default": "Send message" },
    "successMessage": { "type": "string", "default": "Thanks! We'll be in touch soon." }
  },
  "cssTokens": ["--sc-surface", "--sc-border", "--sc-primary", "--sc-input"],
  "targets": {
    "angular": "sections/contact-form/contact-form.section.component",
    "react": "sections/ContactForm",
    "html": "sections/contact-form.html"
  }
}
