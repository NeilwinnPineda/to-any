{
  "id": "chart-placeholder",
  "label": "Chart Placeholder",
  "description": "Labeled chart container. Accepts any chart library (Chart.js, Recharts, ApexCharts). Defines the slot, data key, and chart type — not the chart itself.",
  "variants": ["line", "bar", "pie", "donut", "area", "scatter"],
  "defaultVariant": "line",
  "contentKey": "dashboard.charts",
  "fields": {
    "title": { "type": "string", "required": true },
    "chartType": { "type": "enum", "values": ["line", "bar", "pie", "donut", "area", "scatter"] },
    "dataKey": { "type": "string", "description": "Key in dashboard.json that provides chart data" },
    "height": { "type": "string", "default": "300px" },
    "showLegend": { "type": "boolean", "default": true },
    "showTooltip": { "type": "boolean", "default": true }
  },
  "cssTokens": ["--sc-surface", "--sc-border", "--sc-primary", "--sc-radius"],
  "targets": {
    "angular": "sections/chart/chart-placeholder.section.component",
    "react": "sections/ChartPlaceholder",
    "html": "sections/chart-placeholder.html"
  }
}
