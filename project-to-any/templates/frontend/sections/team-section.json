{
  "id": "team-section",
  "label": "Team Section",
  "description": "Grid of team member cards with photo, name, role, and social links.",
  "variants": ["grid", "list", "featured-plus-grid", "minimal"],
  "defaultVariant": "grid",
  "contentKey": "team",
  "fields": {
    "headline": { "type": "string", "required": false },
    "subheadline": { "type": "string", "required": false },
    "members": {
      "type": "array",
      "schema": {
        "id": "string",
        "name": "string",
        "role": "string",
        "bio": "string|null",
        "avatar": "string",
        "social": {
          "twitter": "string|null",
          "linkedin": "string|null",
          "github": "string|null"
        }
      },
      "required": true
    }
  },
  "cssTokens": ["--sc-surface", "--sc-text", "--sc-text-2", "--sc-primary"],
  "targets": {
    "angular": "sections/team/team.section.component",
    "react": "sections/TeamSection",
    "html": "sections/team-section.html"
  }
}
