{
  "id": "service-cards",
  "label": "Service Cards",
  "description": "Grid of service offering cards with icon, title, description, and learn-more link.",
  "variants": ["3-col", "2-col", "horizontal-list", "with-image"],
  "defaultVariant": "3-col",
  "contentKey": "services",
  "fields": {
    "headline": { "type": "string", "required": false },
    "subheadline": { "type": "string", "required": false },
    "items": {
      "type": "array",
      "schema": {
        "id": "string",
        "icon": "string",
        "title": "string",
        "description": "string",
        "href": "string",
        "image": "string|null",
        "tags": "string[]|null"
      },
      "required": true
    }
  },
  "cssTokens": ["--sc-surface", "--sc-border", "--sc-primary", "--sc-radius"],
  "targets": {
    "angular": "sections/service-cards/service-cards.section.component",
    "react": "sections/ServiceCards",
    "html": "sections/service-cards.html"
  }
}
