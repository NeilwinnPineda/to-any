{
  "id": "newsletter-signup",
  "label": "Newsletter Signup",
  "description": "Email capture section: headline, one-line description, email input, submit. Inline or full-width band.",
  "variants": ["inline-band", "centered", "split", "floating-card"],
  "defaultVariant": "inline-band",
  "contentKey": "newsletter",
  "fields": {
    "headline": { "type": "string", "required": true },
    "subheadline": { "type": "string", "required": false },
    "placeholder": { "type": "string", "default": "Enter your email" },
    "submitLabel": { "type": "string", "default": "Subscribe" },
    "privacyNote": { "type": "string", "required": false },
    "successMessage": { "type": "string", "default": "You're in! Check your inbox." }
  },
  "cssTokens": ["--sc-primary", "--sc-surface", "--sc-input", "--sc-text"],
  "targets": {
    "angular": "sections/newsletter/newsletter.section.component",
    "react": "sections/NewsletterSignup",
    "html": "sections/newsletter-signup.html"
  }
}
