{
  "id": "faq-accordion",
  "label": "FAQ Accordion",
  "description": "Collapsible Q&A list. Supports categories/tabs for large FAQ sets.",
  "variants": ["simple", "with-categories", "two-column", "search-enabled"],
  "defaultVariant": "simple",
  "contentKey": "faqs",
  "fields": {
    "headline": { "type": "string", "required": false },
    "subheadline": { "type": "string", "required": false },
    "categories": { "type": "string[]", "required": false },
    "items": {
      "type": "array",
      "schema": {
        "question": "string",
        "answer": "string",
        "category": "string|null",
        "open": "boolean"
      },
      "required": true
    }
  },
  "cssTokens": ["--sc-surface", "--sc-border", "--sc-text", "--sc-primary"],
  "targets": {
    "angular": "sections/faq-accordion/faq-accordion.section.component",
    "react": "sections/FaqAccordion",
    "html": "sections/faq-accordion.html"
  }
}
