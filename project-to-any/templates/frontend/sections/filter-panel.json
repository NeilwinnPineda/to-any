{
  "id": "filter-panel",
  "label": "Filter Panel",
  "description": "Left-panel or inline filter controls: checkboxes, range sliders, dropdowns, tag filters. Used with product grid, blog, and search results.",
  "variants": ["sidebar", "inline-bar", "modal", "collapsible-groups"],
  "defaultVariant": "sidebar",
  "contentKey": "filters",
  "fields": {
    "groups": {
      "type": "array",
      "schema": {
        "id": "string",
        "label": "string",
        "type": "checkbox|radio|range|select|tags",
        "options": "array",
        "collapsed": "boolean"
      },
      "required": true
    },
    "showClearAll": { "type": "boolean", "default": true },
    "showActiveCount": { "type": "boolean", "default": true }
  },
  "cssTokens": ["--sc-surface", "--sc-border", "--sc-text", "--sc-primary", "--sc-input"],
  "targets": {
    "angular": "sections/filter-panel/filter-panel.section.component",
    "react": "sections/FilterPanel",
    "html": "sections/filter-panel.html"
  }
}
